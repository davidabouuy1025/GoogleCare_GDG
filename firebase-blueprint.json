{
  "entities": {
    "User": {
      "title": "User",
      "description": "Patient profile information",
      "type": "object",
      "properties": {
        "patientID": { "type": "string", "description": "Unique identifier for the patient" },
        "patientName": { "type": "string", "description": "Full name of the patient" },
        "patientAge": { "type": "integer", "description": "Age of the patient" },
        "patientAddress": { "type": "string", "description": "Residential address" },
        "patientContactNo": { "type": "string", "description": "Primary contact number" },
        "patientEmergencyContact": { "type": "string", "description": "Emergency contact number" },
        "patientCondition": {"type": "string", "description":"Current medical condition"},
        "patientAllergy": {"type": "string", "description": "Allergies"},
        "patientBloodType": {"type": "string", "description": "Bloof type"},
        "checkInDeadline": { "type": "string", "description": "Daily check-in deadline time (HH:mm)" },
        "lastCheckIn": { "type": "string", "description": "Timestamp of last check-in" },
        "deadlineMissed": { "type": "boolean", "description": "Whether the last deadline was missed" },
        "forceCheckIn": {"type":"boolean", "description": "Whether daily check-in is compulsory"}
      },
      "required": ["patientID", "patientName"]
    },
    "Symptom": {
      "title": "Symptom",
      "description": "Recorded symptom analysis",
      "type": "object",
      "properties": {
        "patientID": { "type": "string", "description": "ID of the patient" },
        "Symptom": { "type": "string", "description": "Description of the symptom" },
        "riskLevel": { "type": "string", "description": "Assessed risk level (Low, Medium, High)" },
        "confidenceScore": { "type": "number", "description": "Confidence score of the analysis" },
        "date": { "type": "string", "format": "date-time", "description": "Date of recording" }
      },
      "required": ["patientID", "Symptom"]
    },
    "Mood": {
      "title": "Mood",
      "description": "Daily mood check-in",
      "type": "object",
      "properties": {
        "patientID": { "type": "string", "description": "ID of the patient" },
        "date": { "type": "string", "format": "date-time", "description": "Date of recording" },
        "mood": { "type": "string", "description": "Mood status" },
        "remark": { "type": "string", "description": "Additional notes" },
        "assessment": { "type": "string", "description": "AI assessment" },
        "riskLevel": { "type": "string", "description": "Assessed risk level" }
      },
      "required": ["patientID", "date", "mood"]
    },
    "Wound": {
      "title": "Wound",
      "description": "Wound analysis record",
      "type": "object",
      "properties": {
        "patientID": { "type": "string", "description": "ID of the patient" },
        "type": { "type": "string", "description": "Type of wound" },
        "analysis": { "type": "string", "description": "Detailed analysis" },
        "recommendations": { "type": "string", "description": "Care recommendations" },
        "date": { "type": "string", "format": "date-time", "description": "Date of recording" }
      },
      "required": ["patientID", "type", "analysis", "date"]
    },
      "ForumPost": {
      "title": "Forum Post",
      "description": "A post in the community forum",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "organRelated": { "type": "string", "enum": ["General", "Heart", "Kidney", "Lung", "Stomach", "Brain", "Other"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "replyCount": { "type": "integer" }
      },
      "required": ["authorId", "authorName", "title", "content", "organRelated", "createdAt"]
    },
    "ForumReply": {
      "title": "Forum Reply",
      "description": "A reply to a forum post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{patientID}": {
      "schema": "User",
      "description": "Collection of patient profiles"
    },
    "/symptoms/{symptomId}": {
      "schema": "Symptom",
      "description": "Collection of symptom records"
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Collection of mood records"
    },
    "/wounds/{woundId}": {
      "schema": "Wound",
      "description": "Collection of wound records"
    },
    "/forum_posts/{postId}": {
      "schema": "ForumPost",
      "description": "Collection of community forum posts"
    },
    "/forum_replies/{replyId}": {
      "schema": "ForumReply",
      "description": "Collection of replies to forum posts"
    }
  }
}
